class HoverBehavior(object):
    hovered = BooleanProperty(False)

    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        Window.bind(mouse_pos=self.on_mouse_pos)

    def on_mouse_pos(self, *args):
        if not self.get_root_window():
            return
        pos = args[1]
        inside = self.collide_point(*self.to_widget(*pos))
        self.hovered = inside


class HoverButton(HoverBehavior, Button):
    pass
from kivy.clock import Clock
from datetime import datetime

class HomePageScreen(Screen):
    def on_enter(self):
        # Set your target date here
        self.target = datetime(2026, 2, 11, 7, 0, 0)  # year, month, day, hour, minute, second

        # Update every second
        Clock.schedule_interval(self.update_countdown, 1)

    def update_countdown(self, dt):
        now = datetime.now()
        remaining = self.target - now

        if remaining.total_seconds() <= 0:
            self.ids.countdown_label.text = "Race has started!"
            return

        days = remaining.days
        hours, remainder = divmod(remaining.seconds, 3600)
        minutes, seconds = divmod(remainder, 60)

        self.ids.countdown_label.text = f"{days}d {hours}h {minutes}m {seconds}s"

